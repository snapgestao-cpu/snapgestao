{
  "expo": {
    "name": "SnapGestão",
    "slug": "snapgestao",
    "scheme": "snapgestao",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#65a7c1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapgestao.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#65a7c1"
      },
      "package": "com.snapgestao.app",
      "versionCode": 2,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAsyncStorageFix",
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "O SnapGestão precisa da câmera para escanear cupons fiscais."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir acesso para salvar relatórios PDF.",
          "savePhotosPermission": "Permitir salvar relatórios PDF.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ]
  }
}
